# Slack App credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub
GITHUB_TOKEN=ghp_your-personal-access-token-here
GITHUB_REPO=your-org/your-repo

# App configuration
# Comma-separated Slack user IDs allowed to trigger issue creation via 🐛 reaction
AUTHORIZED_SLACK_USERS=U01234567,U07654321

# Slack channel ID for the dedicated bug intake channel (bypasses quality gate)
BUG_CHANNEL_ID=C01234567

# Cosine similarity threshold above which a bug is considered a duplicate (0.0–1.0)
DUPLICATE_THRESHOLD=0.85
